# Google Maps JavaScript API key (required for the map display)
# Get one at: https://console.cloud.google.com/
# Enable: Maps JavaScript API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional: Google Maps Map ID for AdvancedMarkerElement support
# Create a Map ID at: https://console.cloud.google.com/google/maps-apis/studio/maps
# If omitted, falls back to DEMO_MAP_ID (fine for development)
VITE_GOOGLE_MAPS_MAP_ID=your_map_id_here

# Google Geocoding API key for the preprocessing script (can be same as above)
# Enable: Geocoding API in the Google Cloud Console
# If omitted, the script uses OpenStreetMap Nominatim (free, no key needed)
GOOGLE_GEOCODING_API_KEY=your_geocoding_api_key_here
